# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Supabase — paste from your project's Settings > API page
# (Service role key is server-only; never expose to the browser.)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: a shared secret to protect the admin lead-listing route
ADMIN_TOKEN=change-me-to-a-long-random-string

# Required for production: the HMAC secret used to sign user session tokens.
# In dev (or seed-mode) a sane fallback is used. Always override for any
# real deployment — rotating this value invalidates every active session.
AUTH_SECRET=change-me-to-a-long-random-string-too

# Optional: base URL where the frontend lives — used to build SIP share links
PUBLIC_FRONTEND_URL=http://localhost:3000

# Super Admin bootstrap. On every server boot the backend ensures an
# account with SUPERADMIN_EMAIL exists and has the `superadmin` role. Use
# this credential to log in to the /admin panel.
#   - Leave both blank to disable bootstrap (no /admin login).
#   - Existing users with this email get promoted; passwords are NEVER
#     overwritten automatically.
SUPERADMIN_EMAIL=admin@peculiex.local
SUPERADMIN_PASSWORD=change-me-to-a-strong-password
SUPERADMIN_NAME=Super Admin

# Test User bootstrap. On every boot the backend ensures a verified test
# account exists with these credentials. Use it to log in without going
# through the email-OTP flow. Defaults are wired in code so leaving these
# blank still gives you tester@peculiex.local / Test@1234.
TEST_USER_EMAIL=tester@peculiex.local
TEST_USER_PASSWORD=Test@1234
TEST_USER_NAME=Test Investor

# Email (optional). When SMTP_HOST is set the backend tries to load
# `nodemailer` (run `npm install nodemailer` once). Otherwise OTP codes
# are printed to the server console — fine for local dev.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Peculiex <no-reply@peculiex.local>"

# Live market data — Finnhub (https://finnhub.io). Used for company news.
# Indian stock quotes/charts are sourced from Yahoo Finance which needs no
# key. Free Finnhub tier does NOT include NSE/BSE coverage; we still proxy
# news through it because the general-market feed is keyed on this token.
FINNHUB_API_KEY=

# Groww Trade API integration
GROWW_API_KEY=
GROWW_API_SECRET=
