# Backend API base (server-to-server in dev rewrites). Leave http://localhost:4000 in dev.
NEXT_PUBLIC_API_BASE=http://localhost:4000

# WhatsApp chat button — phone in international format, no '+', no spaces.
# Example: 919999999999 for an Indian number +91 99999 99999.
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# Optional: pre-filled message text shown when the WhatsApp chat opens.
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hi Peculiex team! I'd like to know more about investing through your platform.

# Public origin of this site, used for canonical / OG metadata in production.
NEXT_PUBLIC_SITE_URL=https://peculiex.example.com
